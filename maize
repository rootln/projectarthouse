// ── CHARTS ───────────────────────────────────────────────────────────
function buildCharts(){
  const w=document.getElementById('chartWrap');

  // Area distribution histogram (10 bins)
  const areas=maizeFeats.map(f=>f.properties.farm_area_ha);
  const bins=10;
  const binSize=(maxArea-minArea)/bins;
  const hist=Array(bins).fill(0);
  areas.forEach(a=>{ const b=Math.min(Math.floor((a-minArea)/binSize),bins-1); hist[b]++; });
  const maxH=Math.max(...hist);

  // Sowing date distribution
  const sowMap={};
  maizeFeats.forEach(f=>{
    const d=f.properties.sowing_date||'Unknown';
    const mo=d.slice(0,7); // YYYY-MM
    sowMap[mo]=(sowMap[mo]||0)+1;
  });
  const sowEntries=Object.entries(sowMap).sort();
  const maxSow=Math.max(...sowEntries.map(e=>e[1]));

  w.innerHTML=`
  <div class="chart-card">
    <div class="chart-title">Farm Area Distribution (ha) — 100 Maize Parcels</div>
    <div class="bar-chart">
      ${hist.map((cnt,i)=>{
        const lo=(minArea+i*binSize).toFixed(2);
        const hi=(minArea+(i+1)*binSize).toFixed(2);
        const pct=Math.round((cnt/maxH)*100);
        return `<div class="bar-row">
          <div class="bar-lbl">${lo}–${hi}</div>
          <div class="bar-fill" style="width:${pct}%"></div>
          <div class="bar-val">${cnt}</div>
        </div>`;
      }).join('')}
    </div>
  </div>

  <div class="chart-card">
    <div class="chart-title">Sowing Date Distribution (Month)</div>
    <div class="bar-chart">
      ${sowEntries.map(([mo,cnt])=>{
        const pct=Math.round((cnt/maxSow)*100);
        return `<div class="bar-row">
          <div class="bar-lbl">${mo}</div>
          <div class="bar-fill" style="width:${pct}%"></div>
          <div class="bar-val">${cnt}</div>
        </div>`;
      }).join('')}
    </div>
  </div>

  <div class="chart-card">
    <div class="chart-title">Summary Statistics</div>
    <div class="detail-row" style="padding:5px 0;border-bottom:1px solid var(--border);font-size:.75rem;display:flex;justify-content:space-between;">
      <span style="color:var(--dim);font-family:var(--mono)">Total Parcels</span><span style="color:var(--accent);font-weight:600">100</span></div>
    <div class="detail-row" style="padding:5px 0;border-bottom:1px solid var(--border);font-size:.75rem;display:flex;justify-content:space-between;">
      <span style="color:var(--dim);font-family:var(--mono)">Total Farm Area</span><span style="color:var(--accent);font-weight:600">45.64 ha</span></div>
    <div class="detail-row" style="padding:5px 0;border-bottom:1px solid var(--border);font-size:.75rem;display:flex;justify-content:space-between;">
      <span style="color:var(--dim);font-family:var(--mono)">Average per Parcel</span><span style="color:var(--accent);font-weight:600">0.456 ha</span></div>
    <div class="detail-row" style="padding:5px 0;border-bottom:1px solid var(--border);font-size:.75rem;display:flex;justify-content:space-between;">
      <span style="color:var(--dim);font-family:var(--mono)">Min Parcel Area</span><span style="color:var(--text);font-weight:600">${minArea.toFixed(4)} ha</span></div>
    <div class="detail-row" style="padding:5px 0;border-bottom:1px solid var(--border);font-size:.75rem;display:flex;justify-content:space-between;">
      <span style="color:var(--dim);font-family:var(--mono)">Max Parcel Area</span><span style="color:var(--text);font-weight:600">${maxArea.toFixed(4)} ha</span></div>
    <div class="detail-row" style="padding:5px 0;font-size:.75rem;display:flex;justify-content:space-between;">
      <span style="color:var(--dim);font-family:var(--mono)">Village</span><span style="color:var(--text);font-weight:600">Jonnathali Agraharam</span></div>
  </div>`;
}
buildCharts();

