function switchTab(el,id){
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  document.getElementById(id).classList.add('active');
}
window.switchTab=switchTab;
function switchTabByName(id){
  const tabs=document.querySelectorAll('.tab');
  const contents=document.querySelectorAll('.tab-content');
  contents.forEach((c,i)=>{ if(c.id===id){c.classList.add('active');tabs[i].classList.add('active');}
                              else{c.classList.remove('active');tabs[i].classList.remove('active');} });
}

// ── EXPORTS ───────────────────────────────────────────────────────────
function exportCSV(){
  const cols=Object.keys(meta[0]);
  const csv=[cols.join(','),...meta.map(r=>cols.map(c=>`"${r[c]}"`).join(','))].join('\n');
  dl(new Blob([csv],{type:'text/csv'}),'bapatla_100_maize_parcels.csv');
}
function exportGeoJSON(){
  const gj2={type:'FeatureCollection',features:maizeFeats};
  dl(new Blob([JSON.stringify(gj2,null,2)],{type:'application/json'}),'bapatla_100_maize_parcels.geojson');
}
function dl(blob,name){const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=name;a.click();}
window.exportCSV=exportCSV; window.exportGeoJSON=exportGeoJSON;
