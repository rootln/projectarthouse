<script>
// ── DATA ──────────────────────────────────────────────────────────
const gj = GEOJSON_DATA;
const meta = META_DATA;
const maizeFeats = gj.features.filter(f=>f.properties.is_maize);
const maxArea = Math.max(...maizeFeats.map(f=>f.properties.farm_area_ha));
const minArea = Math.min(...maizeFeats.map(f=>f.properties.farm_area_ha));

// ── MAP INIT ────────────────────────────────────────────────────────
const map = L.map('map',{zoomControl:true,attributionControl:false});
L.control.attribution({prefix:'© OSM | Leaflet | ePanta 2025'}).addTo(map);
let baseLayers={};

const TILES={
  dark:['https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{maxZoom:20,subdomains:'abcd'}],
  sat:['https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',{maxZoom:19}],
  topo:['https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png',{maxZoom:17,subdomains:'abc'}],
};

let currentBase=null;
function setBase(el,mode){
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('on'));
  if(el)el.classList.add('on');
  if(currentBase)map.removeLayer(currentBase);
  currentBase=L.tileLayer(...TILES[mode]).addTo(map);
}
window.setBase=setBase;
setBase(null,'dark');

// ── COLOUR MAP ──────────────────────────────────────────────────────
function maizeColor(ha){
  const t=(ha-minArea)/(maxArea-minArea||1);
  const r=Math.round(255),g=Math.round(210-(210-107)*t),b=Math.round(0);
  return `rgb(${r},${g},${b})`;
}

// ── RENDER LAYERS ───────────────────────────────────────────────────
let parcelLayers={};
let selectedIdx=null;

// Context parcels (non-maize)
const ctxFeats=gj.features.filter(f=>!f.properties.is_maize);
L.geoJSON({type:'FeatureCollection',features:ctxFeats},{
  style:{fillColor:'#162030',fillOpacity:.75,color:'#1e3a55',weight:.5}
}).addTo(map);

// Maize parcels
maizeFeats.forEach((feat,i)=>{
  const p=feat.properties;
  const layer=L.geoJSON(feat,{
    style:{fillColor:maizeColor(p.farm_area_ha),fillOpacity:.92,color:'#ffd200',weight:1.1},
    onEachFeature:(f,l)=>{
      l.on('mouseover',()=>{
        l.setStyle({fillOpacity:.7,weight:2});
        document.getElementById('hoverInfo').textContent=
          `LPM ${p.lpm_number} · ${p.village_name} · ${p.farm_area_ha} ha`;
      });
      l.on('mouseout',()=>{
        if(selectedIdx!==i) l.setStyle({fillColor:maizeColor(p.farm_area_ha),fillOpacity:.92,color:'#ffd200',weight:1.1});
        document.getElementById('hoverInfo').textContent='Hover a parcel for quick info';
      });
      l.on('click',()=>selectParcel(i,feat,l));
      l.bindPopup(buildPopup(p),{maxWidth:280});
    }
  }).addTo(map);
  parcelLayers[i]={layer,feat};
});

function selectParcel(idx,feat,leafLayer){
  // Reset previous
  if(selectedIdx!==null && parcelLayers[selectedIdx]){
    const prev=parcelLayers[selectedIdx];
    prev.layer.setStyle({fillColor:maizeColor(prev.feat.properties.farm_area_ha),fillOpacity:.92,color:'#ffd200',weight:1.1});
  }
  selectedIdx=idx;
  leafLayer.setStyle({fillColor:'#ffffff',fillOpacity:.5,color:'#ffffff',weight:2.5});
  showDetail(feat.properties, idx+1);
  highlightRow(idx);
  switchTabByName('tab-detail');
}

function buildPopup(p){
  return `<div class="pop-badge">🌽 MAIZE · Rabi 2025</div>
  <div class="pop-title">LPM ${p.lpm_number}</div>
  <div class="pop-row"><span class="pop-k">Village</span><span class="pop-v">${p.village_name}</span></div>
  <div class="pop-row"><span class="pop-k">Khata No.</span><span class="pop-v">${p.khata_numb}</span></div>
  <div class="pop-row"><span class="pop-k">Farm Area</span><span class="pop-v">${p.farm_area_ha} ha (${p.farm_area_acres} ac)</span></div>
  <div class="pop-row"><span class="pop-k">Crop Area</span><span class="pop-v">${p.crop_area_guntas} guntas</span></div>
  <div class="pop-row"><span class="pop-k">Sowing Date</span><span class="pop-v">${p.sowing_date}</span></div>
  <div class="pop-row"><span class="pop-k">Block</span><span class="pop-v">${p.block}</span></div>
  <div class="pop-row"><span class="pop-k">LGD Code</span><span class="pop-v">${p.village_lgd}</span></div>
  <div class="pop-row"><span class="pop-k">Source</span><span class="pop-v">${p.source}</span></div>`;
}

// ── FIT MAP ──────────────────────────────────────────────────────────
function fitMap(){
  const bounds=L.geoJSON({type:'FeatureCollection',features:maizeFeats}).getBounds();
  map.fitBounds(bounds,{padding:[30,30]});
}
window.fitMap=fitMap;
setTimeout(fitMap,500);

// ── METADATA TABLE ───────────────────────────────────────────────────
let tableData=[...meta];
let sortKey='#'; let sortAsc=true;

function renderTable(data){
  const tbody=document.getElementById('tableBody');
  tbody.innerHTML='';
  data.forEach((row,i)=>{
    const realIdx=maizeFeats.findIndex(f=>f.properties.lpm_number===row['LPM No']);
    const ha=parseFloat(row['Farm Area (ha)']);
    const pct=Math.round((ha/maxArea)*100);
    const tr=document.createElement('tr');
    tr.id=`tr-${realIdx}`;
    tr.innerHTML=`
      <td style="color:var(--dim)">${row['#']}</td>
      <td style="color:var(--accent);font-weight:600">${row['LPM No']}</td>
      <td>${row['Khata No']}</td>
      <td style="max-width:110px;overflow:hidden;text-overflow:ellipsis">${row['Village']}</td>
      <td>
        <div class="area-bar">
          <div class="area-fill" style="width:${pct}%"></div>
          <span style="color:var(--accent)">${ha}</span>
        </div>
      </td>
      <td style="color:#00e5a0">${row['Crop Area (guntas)']}</td>
      <td style="color:var(--dim)">${row['Sowing Date']}</td>
      <td style="color:var(--dim)">${row['Source']}</td>`;
    tr.onclick=()=>{
      if(realIdx>=0){
        const fl=parcelLayers[realIdx];
        if(fl){
          map.fitBounds(fl.layer.getBounds(),{maxZoom:17,padding:[40,40]});
          fl.layer.openPopup();
          selectParcel(realIdx,fl.feat,fl.layer.getLayers()[0]);
        }
      }
    };
    tbody.appendChild(tr);
  });
  document.getElementById('tableFooter').textContent=`Showing ${data.length} of 100 maize parcels`;
}

function filterTable(){
  const q=document.getElementById('searchBox').value.toLowerCase();
  const filtered=meta.filter(r=>
    r['LPM No'].includes(q)||r['Khata No'].includes(q)||
    r['Village'].toLowerCase().includes(q)||r['Sowing Date'].includes(q)
  );
  renderTable(applySort(filtered));
}

function sortBy(key){
  if(sortKey===key) sortAsc=!sortAsc; else{sortKey=key;sortAsc=true;}
  document.querySelectorAll('thead th').forEach(th=>th.classList.remove('sorted'));
  renderTable(applySort(tableData));
}
window.sortBy=sortBy;

function applySort(data){
  return [...data].sort((a,b)=>{
    let av=a[sortKey]||'', bv=b[sortKey]||'';
    const an=parseFloat(av), bn=parseFloat(bv);
    if(!isNaN(an)&&!isNaN(bn)) return sortAsc?an-bn:bn-an;
    return sortAsc?av.localeCompare(bv):bv.localeCompare(av);
  });
}

function highlightRow(idx){
  document.querySelectorAll('tbody tr').forEach(r=>r.classList.remove('highlighted'));
  const tr=document.getElementById(`tr-${idx}`);
  if(tr){tr.classList.add('highlighted');tr.scrollIntoView({block:'nearest',behavior:'smooth'});}
}

renderTable(meta);

