<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Bapatla — 100 Maize Parcels · Cadastral Intelligence</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@300;400;500&display=swap');
:root{
  --bg:#060d18;--surf:#0b1929;--panel:#0f2035;--border:#173250;
  --accent:#ffd200;--accent2:#ff6b00;--green:#00e5a0;--red:#ff4060;
  --text:#cce0f5;--dim:#3a6a8a;--mono:'IBM Plex Mono',monospace;--sans:'Space Grotesk',sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--bg);color:var(--text);font-family:var(--sans);height:100vh;display:flex;flex-direction:column;overflow:hidden;}

/* ── TOP BAR ── */
header{display:flex;align-items:center;justify-content:space-between;padding:10px 20px;
  background:var(--surf);border-bottom:1px solid var(--border);flex-shrink:0;z-index:200;}
.hdr-left{display:flex;align-items:center;gap:10px;}
.hdr-badge{background:var(--accent);color:#060d18;font-weight:700;font-size:.65rem;
  padding:3px 8px;border-radius:12px;letter-spacing:.06em;}
.hdr-title{font-size:1rem;font-weight:700;letter-spacing:-.02em;}
.hdr-title span{color:var(--accent);}
.hdr-meta{font-size:.7rem;color:var(--dim);font-family:var(--mono);}
.hdr-stats{display:flex;gap:20px;}
.hdr-stat{text-align:center;}
.hdr-stat-v{font-size:1.1rem;font-weight:700;color:var(--accent);line-height:1;}
.hdr-stat-l{font-size:.62rem;color:var(--dim);font-family:var(--mono);}
.btn{font-family:var(--sans);font-weight:600;font-size:.75rem;padding:7px 14px;
  border-radius:6px;cursor:pointer;border:none;transition:all .18s;letter-spacing:.03em;}
.btn-gold{background:var(--accent);color:#060d18;}
.btn-gold:hover{filter:brightness(1.1);transform:translateY(-1px);}
.btn-ghost{background:transparent;border:1px solid var(--border);color:var(--text);}
.btn-ghost:hover{border-color:var(--accent);color:var(--accent);}

/* ── MAIN LAYOUT ── */
.main{display:grid;grid-template-columns:1fr 420px;flex:1;min-height:0;overflow:hidden;}

/* ── MAP AREA ── */
.map-col{display:flex;flex-direction:column;min-height:0;}
.map-toolbar{display:flex;align-items:center;gap:8px;padding:8px 14px;
  background:var(--surf);border-bottom:1px solid var(--border);flex-shrink:0;}
.chip{font-size:.68rem;font-family:var(--mono);padding:4px 10px;border-radius:20px;
  border:1px solid var(--border);cursor:pointer;color:var(--dim);transition:all .18s;}
.chip:hover,.chip.on{border-color:var(--accent);color:var(--accent);background:rgba(255,210,0,.07);}
#map{flex:1;min-height:0;}
.map-legend{position:absolute;bottom:30px;left:14px;z-index:500;
  background:rgba(6,13,24,.88);border:1px solid var(--border);border-radius:8px;
  padding:10px 14px;backdrop-filter:blur(8px);}
.leg-row{display:flex;align-items:center;gap:7px;font-size:.7rem;
  font-family:var(--mono);color:var(--text);margin-bottom:5px;}
.leg-row:last-child{margin-bottom:0;}
.leg-dot{width:11px;height:11px;border-radius:2px;flex-shrink:0;}

/* ── RIGHT PANEL ── */
.right-panel{display:flex;flex-direction:column;border-left:1px solid var(--border);
  background:var(--surf);min-height:0;overflow:hidden;}
.tab-bar{display:flex;border-bottom:1px solid var(--border);flex-shrink:0;}
.tab{flex:1;padding:10px 6px;text-align:center;font-size:.72rem;font-weight:600;
  cursor:pointer;color:var(--dim);border-bottom:2px solid transparent;transition:all .2s;letter-spacing:.04em;}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);background:rgba(255,210,0,.04);}
.tab-content{flex:1;min-height:0;overflow:hidden;display:none;}
.tab-content.active{display:flex;flex-direction:column;}

/* ── METADATA TABLE ── */
.table-toolbar{display:flex;align-items:center;gap:8px;padding:10px 12px;
  border-bottom:1px solid var(--border);flex-shrink:0;}
.search-box{flex:1;background:var(--panel);border:1px solid var(--border);
  color:var(--text);padding:6px 10px;border-radius:6px;font-family:var(--mono);
  font-size:.75rem;outline:none;}
.search-box:focus{border-color:var(--accent);}
.table-wrap{flex:1;overflow-y:auto;overflow-x:auto;}
.table-wrap::-webkit-scrollbar{width:4px;height:4px;}
.table-wrap::-webkit-scrollbar-thumb{background:var(--border);}
table{width:100%;border-collapse:collapse;font-size:.7rem;font-family:var(--mono);}
thead th{position:sticky;top:0;background:var(--panel);color:var(--dim);
  font-weight:500;padding:7px 10px;text-align:left;border-bottom:1px solid var(--border);
  white-space:nowrap;cursor:pointer;user-select:none;letter-spacing:.04em;}
thead th:hover{color:var(--accent);}
thead th.sorted{color:var(--accent);}
tbody tr{border-bottom:1px solid rgba(23,50,80,.5);cursor:pointer;transition:background .12s;}
tbody tr:hover{background:rgba(255,210,0,.05);}
tbody tr.highlighted{background:rgba(255,210,0,.12)!important;border-left:2px solid var(--accent);}
tbody td{padding:5px 10px;white-space:nowrap;color:var(--text);}
.badge-maize{display:inline-block;padding:2px 7px;border-radius:10px;
  background:linear-gradient(135deg,#ffd200,#ff6b00);color:#060d18;font-weight:700;font-size:.62rem;}
.area-bar{display:flex;align-items:center;gap:5px;}
.area-fill{height:4px;border-radius:2px;background:linear-gradient(90deg,#ffd200,#ff6b00);min-width:2px;}
.table-footer{padding:7px 12px;border-top:1px solid var(--border);font-size:.68rem;
  font-family:var(--mono);color:var(--dim);flex-shrink:0;}

/* ── DETAIL PANEL ── */
.detail-wrap{flex:1;overflow-y:auto;padding:14px;}
.detail-wrap::-webkit-scrollbar{width:4px;}
.detail-wrap::-webkit-scrollbar-thumb{background:var(--border);}
.detail-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;
  height:100%;color:var(--dim);font-size:.8rem;gap:8px;}
.detail-empty-icon{font-size:2rem;}
.detail-card{background:var(--panel);border:1px solid var(--border);border-radius:10px;
  padding:14px;margin-bottom:12px;}
.detail-card-title{font-size:.62rem;font-weight:700;color:var(--dim);letter-spacing:.1em;
  text-transform:uppercase;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.detail-card-title::before{content:'';width:12px;height:2px;background:var(--accent);border-radius:1px;}
.detail-row{display:flex;justify-content:space-between;padding:5px 0;
  border-bottom:1px solid rgba(23,50,80,.5);font-size:.76rem;}
.detail-row:last-child{border-bottom:none;}
.detail-key{color:var(--dim);font-family:var(--mono);}
.detail-val{color:var(--text);font-weight:500;text-align:right;}
.detail-val.accent{color:var(--accent);}
.parcel-id{font-size:1.3rem;font-weight:700;color:var(--accent);font-family:var(--mono);margin-bottom:4px;}
.sow-timeline{display:flex;flex-direction:column;gap:4px;margin-top:8px;}
.sow-bar{display:flex;align-items:center;gap:6px;font-size:.68rem;font-family:var(--mono);color:var(--dim);}
.sow-dot{width:8px;height:8px;border-radius:50%;background:var(--accent);flex-shrink:0;}

/* ── CHART TAB ── */
.chart-wrap{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:14px;}
.chart-wrap::-webkit-scrollbar{width:4px;}
.chart-wrap::-webkit-scrollbar-thumb{background:var(--border);}
.chart-card{background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:14px;}
.chart-title{font-size:.68rem;color:var(--dim);font-weight:600;letter-spacing:.08em;
  text-transform:uppercase;margin-bottom:12px;}
.bar-chart{display:flex;flex-direction:column;gap:5px;}
.bar-row{display:flex;align-items:center;gap:8px;font-size:.68rem;font-family:var(--mono);}
.bar-lbl{width:100px;color:var(--dim);text-overflow:ellipsis;overflow:hidden;white-space:nowrap;flex-shrink:0;}
.bar-fill{height:14px;border-radius:2px;background:linear-gradient(90deg,#ffd200,#ff6b00);
  transition:width .4s ease;min-width:4px;}
.bar-val{color:var(--accent);white-space:nowrap;}
.donut-row{display:flex;align-items:center;gap:16px;}
canvas{border-radius:6px;}
.donut-legend{display:flex;flex-direction:column;gap:6px;font-size:.7rem;font-family:var(--mono);}
.dl-row{display:flex;align-items:center;gap:6px;}
.dl-dot{width:10px;height:10px;border-radius:50%;}

/* leaflet popup */
.leaflet-popup-content-wrapper{background:var(--surf);border:1px solid var(--border);
  box-shadow:0 8px 32px #00000099;border-radius:8px!important;color:var(--text);
  font-family:var(--mono);font-size:.75rem;}
.leaflet-popup-tip{background:var(--surf);}
.leaflet-popup-close-button{color:var(--dim)!important;}
.pop-title{font-size:.9rem;font-weight:700;color:var(--accent);margin-bottom:8px;font-family:var(--sans);}
.pop-badge{display:inline-block;padding:2px 7px;border-radius:10px;
  background:linear-gradient(135deg,#ffd200,#ff6b00);color:#060d18;font-weight:700;
  font-size:.65rem;margin-bottom:6px;}
.pop-row{display:flex;justify-content:space-between;gap:18px;padding:3px 0;
  border-bottom:1px solid var(--border);}
.pop-row:last-child{border-bottom:none;}
.pop-k{color:var(--dim);}.pop-v{color:var(--text);font-weight:500;}
</style>
</head>
